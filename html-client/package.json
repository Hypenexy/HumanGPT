{
  "name": "html-client",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "script.js",
  "scripts": {
    "build:html": "html-minifier-terser --collapse-whitespace --remove-comments --minify-css true --minify-js true index.html -o ../dist/index.html",
    "build:css": "cleancss -o ../dist/style.css style.css",
    "build:js": "terser script.js -c -m -o ../dist/script.js",
    "build": "npm run build:html && npm run build:css && npm run build:js"
  },
  "devDependencies": {
    "clean-css-cli": "^5.6.3",
    "html-minifier-terser": "^7.2.0"
  }
}
